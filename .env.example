# Ops Board shared defaults
OPS_BOARD_TIMEZONE=America/Toronto
OPS_BOARD_TAILSCALE_HOSTNAME=your-hostname
OPS_BOARD_BACKUP_ROOT=D:\ops-board-backups

# SigNoz image pins.
SIGNOZ_VERSION=v0.125.1
SIGNOZ_OTELCOL_TAG=v0.144.4

# SigNoz published ports.
SIGNOZ_HTTP_PORT=8080
SIGNOZ_OTLP_GRPC_PORT=4317
SIGNOZ_OTLP_HTTP_PORT=4318
SIGNOZ_COLLECTOR_HEALTH_PORT=13133

# Docker secret file paths are resolved relative to stacks/signoz/compose.yaml.
# Do not put secret values in this file.
SIGNOZ_JWT_SECRET_FILE=../../secrets/signoz_jwt_secret

# Optional restricted-network mirror for the ClickHouse histogram binary.
# Leave empty to use SigNoz's default GitHub release URL.
HISTOGRAM_QUANTILE_URL=

# Public URLs used by Homepage links and docs.
# Use localhost for first local setup. Change these to Tailscale MagicDNS URLs
# when accessing from other tailnet devices.
SIGNOZ_PUBLIC_URL=http://localhost:8080

# Uptime Kuma
UPTIME_KUMA_VERSION=2
UPTIME_KUMA_PORT=3001
UPTIME_KUMA_PUBLIC_URL=http://localhost:3001
UPTIME_KUMA_INTERNAL_URL=http://host.docker.internal:3001
UPTIME_KUMA_STATUS_SLUG=ops-board
UPTIME_KUMA_DB_TYPE=embedded-mariadb
UPTIME_KUMA_ENABLE_EMBEDDED_MARIADB=1
UPTIME_KUMA_ADMIN_USERNAME=ops-board-demo
UPTIME_KUMA_ADMIN_PASSWORD_FILE=secrets/uptime_kuma_admin_password
UPTIME_KUMA_BOOTSTRAP_CONFIG=stacks/uptime-kuma/bootstrap/monitors.yaml

# Homepage
HOMEPAGE_VERSION=v1.13.1
HOMEPAGE_PORT=3000
HOMEPAGE_PUBLIC_URL=http://localhost:3000
HOMEPAGE_ALLOWED_HOSTS=localhost:3000,127.0.0.1:3000,your-hostname:3000

# Plane
PLANE_HTTP_PORT=8082
PLANE_PUBLIC_URL=http://localhost:8082
PLANE_WEB_URL=http://localhost:8082

# Onboarding playground
DUMMY_API_PUBLIC_URL=http://localhost:18080
