# Ops Board shared defaults
OPS_BOARD_TIMEZONE=America/Toronto
OPS_BOARD_TAILSCALE_HOSTNAME=your-hostname
OPS_BOARD_BACKUP_ROOT=D:\ops-board-backups

# SigNoz image pins.
SIGNOZ_VERSION=v0.125.1
SIGNOZ_OTELCOL_TAG=v0.144.4

# SigNoz published ports.
SIGNOZ_HTTP_PORT=8080
SIGNOZ_OTLP_GRPC_PORT=4317
SIGNOZ_OTLP_HTTP_PORT=4318
SIGNOZ_COLLECTOR_HEALTH_PORT=13133

# Docker secret file paths are resolved relative to stacks/signoz/compose.yaml.
# Do not put secret values in this file.
SIGNOZ_JWT_SECRET_FILE=../../secrets/signoz_jwt_secret

# Optional restricted-network mirror for the ClickHouse histogram binary.
# Leave empty to use SigNoz's default GitHub release URL.
HISTOGRAM_QUANTILE_URL=
