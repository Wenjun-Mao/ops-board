# Local environment files
.env
.env.*
!.env.example

# Stack-local environment files
/stacks/*/*.env
!/stacks/*/*.env.example

# Runtime data and bind-mounted service state
/stacks/*/data/
/stacks/*/runtime/
/stacks/*/outputs/
/stacks/homepage/config/custom.css
/stacks/homepage/config/custom.js
/stacks/homepage/config/docker.yaml
/stacks/homepage/config/kubernetes.yaml
/stacks/homepage/config/proxmox.yaml

# Plane generated installer/runtime files
/stacks/plane/plane-selfhost/
/stacks/plane/plane-app/
/stacks/plane/plane-app-preview/

# Local Docker secret files
/secrets/*
!/secrets/.gitignore

# Backups and archives
/backups/
/backups/**/*.sql
*.bak
*.backup
*.dump
*.sql.dump
*.tar
*.tar.gz
*.zip

# Logs
*.log
logs/
**/logs/

# Python local artifacts
__pycache__/
*.py[cod]
.pytest_cache/
.venv/

# OS/editor files
.DS_Store
Thumbs.db
.idea/
.vscode/

.superpowers/
temp/