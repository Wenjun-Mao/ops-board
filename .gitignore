# Local environment files
.env
.env.*
!.env.example

# Runtime data and bind-mounted service state
/stacks/*/data/
/stacks/*/runtime/
/stacks/*/outputs/

# Local Docker secret files
/secrets/*
!/secrets/.gitignore

# Backups and archives
/backups/
/backups/**/*.sql
*.bak
*.backup
*.dump
*.sql.dump
*.tar
*.tar.gz
*.zip

# Logs
*.log
logs/
**/logs/

# OS/editor files
.DS_Store
Thumbs.db
.idea/
.vscode/
