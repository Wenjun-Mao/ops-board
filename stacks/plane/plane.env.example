APP_DOMAIN=localhost
APP_RELEASE=v1.3.1

WEB_REPLICAS=1
SPACE_REPLICAS=1
ADMIN_REPLICAS=1
API_REPLICAS=1
WORKER_REPLICAS=1
BEAT_WORKER_REPLICAS=1
LIVE_REPLICAS=1

LISTEN_HTTP_PORT=8082
LISTEN_HTTPS_PORT=8443

WEB_URL=http://localhost:8082
PLANE_DEBUG=0
CORS_ALLOWED_ORIGINS=http://localhost:8082
API_BASE_URL=http://api:8000

# DB settings
PGHOST=plane-db
PGDATABASE=plane
POSTGRES_USER=plane
POSTGRES_PASSWORD=change-me
POSTGRES_DB=plane
POSTGRES_PORT=5432
PGDATA=/var/lib/postgresql/data
DATABASE_URL=postgresql://plane:change-me@plane-db/plane

# Redis settings
REDIS_HOST=plane-redis
REDIS_PORT=6379
REDIS_URL=

# RabbitMQ settings
RABBITMQ_HOST=plane-mq
RABBITMQ_PORT=5672
RABBITMQ_USER=plane
RABBITMQ_PASSWORD=change-me
RABBITMQ_VHOST=plane
AMQP_URL=amqp://plane:change-me@plane-mq:5672/plane

# TLS settings are left empty for local/Tailscale-first access.
CERT_ACME_CA=https://acme-v02.api.letsencrypt.org/directory
TRUSTED_PROXIES=0.0.0.0/0
SITE_ADDRESS=:80
CERT_EMAIL=
CERT_ACME_DNS=

# Secret key
SECRET_KEY=change-me

# Data store settings
USE_MINIO=1
AWS_REGION=
AWS_ACCESS_KEY_ID=access-key
AWS_SECRET_ACCESS_KEY=change-me
AWS_S3_ENDPOINT_URL=http://plane-minio:9000
AWS_S3_BUCKET_NAME=uploads
FILE_SIZE_LIMIT=5242880

# Gunicorn workers
GUNICORN_WORKERS=1

# Force HTTPS for handling SSL termination.
MINIO_ENDPOINT_SSL=0

# API key rate limit
API_KEY_RATE_LIMIT=60/minute

# Live server environment variables
LIVE_SERVER_SECRET_KEY=change-me

# Webhook allowlists, comma-separated.
WEBHOOK_ALLOWED_IPS=
WEBHOOK_ALLOWED_HOSTS=
